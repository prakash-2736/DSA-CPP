class Solution {
public:
    int minOperations(vector<int>& nums, int x) {

        int total_sum = accumulate(nums.begin(), nums.end(), 0);
        if(x > total_sum) return -1;
        int k = total_sum - x;

        if(k == 0){
            return nums.size();
        }
        int left = 0;
        int sum = 0;
        int maxi = 0;

        for (int right = 0; right < nums.size(); right++) {
            sum += nums[right];

            while (sum > k) {
                sum -= nums[left];
                left++;
            }
            if (sum == k) {
                maxi = max(maxi, right - left + 1);
            }
        }

        return maxi != 0 ? nums.size() - maxi : -1;
    }
};
